<section class="enrollment-section">
  <div class="container">
    <div class="form-wrapper">
      <div class="form-header">
        <h2 class="form-title">Inscripción de Deportistas</h2>
        <p class="form-subtitle">Completa el formulario para unirte a los equipos del TESCI</p>
      </div>

      <form class="enrollment-form" id="sportsForm">
        <div class="form-grid">
          <!-- Nombre Completo -->
          <div class="form-group full-width">
            <label for="fullname" class="form-label">Nombre Completo</label>
            <input 
              type="text" 
              id="fullname" 
              name="fullname" 
              class="form-input" 
              placeholder="Juan Pérez García"
              required
            >
            <span class="form-error"></span>
          </div>

          <!-- Número de Control -->
          <div class="form-group">
            <label for="controlNumber" class="form-label">Número de Control</label>
            <input 
              type="text" 
              id="controlNumber" 
              name="controlNumber" 
              class="form-input" 
              placeholder="2024001234"
              required
            >
            <span class="form-error"></span>
          </div>

          <!-- Carrera -->
          <div class="form-group">
            <label for="career" class="form-label">Carrera</label>
            <select id="career" name="career" class="form-input" required>
              <option value="">Selecciona tu carrera</option>
              <option value="sistemas">Ingeniería en Sistemas Computacionales</option>
              <option value="industrial">Ingeniería Industrial</option>
              <option value="mecanica">Ingeniería Mecánica</option>
              <option value="civil">Ingeniería Civil</option>
              <option value="electrica">Ingeniería Eléctrica</option>
              <option value="administracion">Administración de Empresas</option>
              <option value="contabilidad">Contabilidad</option>
              <option value="marketing">Marketing Digital</option>
            </select>
            <span class="form-error"></span>
          </div>

          <!-- Semestre -->
          <div class="form-group">
            <label for="semester" class="form-label">Semestre</label>
            <select id="semester" name="semester" class="form-input" required>
              <option value="">Selecciona tu semestre</option>
              <option value="1">1er Semestre</option>
              <option value="2">2do Semestre</option>
              <option value="3">3er Semestre</option>
              <option value="4">4to Semestre</option>
              <option value="5">5to Semestre</option>
              <option value="6">6to Semestre</option>
              <option value="7">7mo Semestre</option>
              <option value="8">8vo Semestre</option>
            </select>
            <span class="form-error"></span>
          </div>

          <!-- Turno -->
          <div class="form-group">
            <label for="shift" class="form-label">Turno</label>
            <select id="shift" name="shift" class="form-input" required>
              <option value="">Selecciona tu turno</option>
              <option value="matutino">Matutino</option>
              <option value="vespertino">Vespertino</option>
              <option value="nocturno">Nocturno</option>
            </select>
            <span class="form-error"></span>
          </div>

          <!-- Disciplina Deportiva -->
          <div class="form-group full-width">
            <label class="form-label">Disciplina Deportiva de Interés</label>
            <div class="checkbox-group">
              <label class="checkbox-label">
                <input type="checkbox" name="sports" value="futbol">
                <span>⚽ Fútbol</span>
              </label>
              <label class="checkbox-label">
                <input type="checkbox" name="sports" value="basquetbol">
                <span>🏀 Básquetbol</span>
              </label>
              <label class="checkbox-label">
                <input type="checkbox" name="sports" value="voleibol">
                <span>🏐 Voleibol</span>
              </label>
            </div>
            <span class="form-error"></span>
          </div>
        </div>

        <button type="submit" class="submit-button">
          <span>Enviar Inscripción</span>
          <svg class="button-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
            <path d="M5 12h14M12 5l7 7-7 7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>

        <p class="form-notice">Los datos serán utilizados únicamente para propósitos deportivos y académicos.</p>
      </form>

      <div class="success-message" id="successMessage" style="display: none;">
        <div class="success-icon">✓</div>
        <h3>¡Inscripción Exitosa!</h3>
        <p>Tu solicitud ha sido registrada. Pronto nos pondremos en contacto contigo.</p>
        <button class="reset-button" onclick="resetForm()">Realizar otra inscripción</button>
      </div>
    </div>

    <div class="form-benefits">
      <h3 class="benefits-title">¿Por qué unirse?</h3>
      <div class="benefits-grid">
        <div class="benefit-card">
          <div class="benefit-icon">🏆</div>
          <h4>Desarrollo</h4>
          <p>Mejora tus habilidades deportivas con entrenamientos profesionales</p>
        </div>
        <div class="benefit-card">
          <div class="benefit-icon">👥</div>
          <h4>Comunidad</h4>
          <p>Forma parte de una comunidad de atletas apasionados</p>
        </div>
        <div class="benefit-card">
          <div class="benefit-icon">🎖️</div>
          <h4>Representación</h4>
          <p>Representa al TESCI en competencias nacionales e internacionales</p>
        </div>
      </div>
    </div>
  </div>
</section>

