<section id="registro" class="enrollment-section">
  <div class="container">

    <div class="form-wrapper">

      <div class="form-header">
        <h2 class="form-title">Inscripción a Taller</h2>
        <p class="form-subtitle">Completa el formulario para registrarte</p>
      </div>

      <form id="sportsForm" class="enrollment-form">

        <div class="form-grid">

          <div class="form-group full-width">
            <label class="form-label">Nombre completo</label>
            <input id="fullname" class="form-input" type="text" required>
          </div>

          <div class="form-group">
            <label class="form-label">Número de control</label>
            <input id="controlNumber" class="form-input" type="text" required>
          </div>

          <div class="form-group">
            <label class="form-label">Carrera</label>
            <select id="career" class="form-input" required>
              <option value="">Selecciona</option>
              <option value="Ingeniería en Sistemas">Ingeniería en Sistemas</option>
              <option value="Ingeniería Industrial">Ingeniería Industrial</option>
              <option value="Ingeniería Mecánica">Ingeniería Mecánica</option>
              <option value="Ingeniería Civil">Ingeniería Civil</option>
              <option value="Ingeniería Eléctrica">Ingeniería Eléctrica</option>
              <option value="Administración">Administración</option>
            </select>
          </div>

          <div class="form-group">
            <label class="form-label">Semestre</label>
            <select id="semester" class="form-input" required>
              <option value="">Selecciona</option>
              <option>1</option>
              <option>2</option>
              <option>3</option>
              <option>4</option>
              <option>5</option>
              <option>6</option>
              <option>7</option>
              <option>8</option>
            </select>
          </div>

          <div class="form-group">
            <label class="form-label">Turno</label>
            <select id="shift" class="form-input" required>
              <option value="">Selecciona</option>
              <option>Matutino</option>
              <option>Vespertino</option>
              
            </select>
          </div>

        </div>

        <button class="submit-button" type="submit">
          Enviar inscripción
        </button>

      </form>

    </div>

  </div>
</section>

<style>

.enrollment-section{
  padding:80px 20px;
  background:#f6f7fb;
  font-family:system-ui;
}

.container{
  max-width:800px;
  margin:auto;
}

.form-wrapper{
  background:white;
  padding:40px;
  border-radius:10px;
  box-shadow:0 10px 30px rgba(0,0,0,0.08);
}

.form-header{
  text-align:center;
  margin-bottom:30px;
}

.form-title{
  font-size:28px;
  margin-bottom:10px;
}

.form-subtitle{
  color:#666;
}

.form-grid{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:20px;
}

.full-width{
  grid-column:1/-1;
}

.form-group{
  display:flex;
  flex-direction:column;
}

.form-label{
  font-size:14px;
  margin-bottom:6px;
}

.form-input{
  padding:12px;
  border:1px solid #ddd;
  border-radius:6px;
  font-size:14px;
}

.submit-button{
  margin-top:30px;
  width:100%;
  padding:16px;
  border:none;
  background:#4f6df5;
  color:white;
  font-size:16px;
  border-radius:6px;
  cursor:pointer;
  display:flex;
  align-items:center;
  justify-content:center;
  font-weight:600;
}

.submit-button:hover{
  background:#3d57d6;
}

@media(max-width:700px){
  .form-grid{
    grid-template-columns:1fr;
  }
}

</style>

<script>

document.addEventListener("DOMContentLoaded", () => {

const form = document.getElementById("sportsForm");

form.addEventListener("submit", function(e){

e.preventDefault();

const fullname = document.getElementById("fullname").value;
const controlNumber = document.getElementById("controlNumber").value;
const career = document.getElementById("career").value;
const semester = document.getElementById("semester").value;
const shift = document.getElementById("shift").value;

if(!fullname || !controlNumber || !career || !semester || !shift ){
alert("Completa todos los campos");
return;
}

const message = 
`¡Hola! Me quiero inscribir al taller de matemáticas del TESCI.

Mis datos son:

Nombre: ${fullname}
Número de control: ${controlNumber}
Carrera: ${career}
Semestre: ${semester}
Turno: ${shift}`;

const phone = "525539542456";

const url = `https://wa.me/${phone}?text=${encodeURIComponent(message)}`;

window.open(url, "_blank");

});

});

</script>