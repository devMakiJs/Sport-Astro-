---
import LinkedIn from '../assets/tikto.svg'
import Twitter from '../assets/face1.svg'
---

<footer>
    <div class="container row">
        <div class="footer-link flex js one-half column">
            <a href="#">About</a> <a href="https://tesci.edomex.gob.mx/directorio">Help Center</a>
            <a href="https://tesci.edomex.gob.mx/sites/tesci.edomex.gob.mx/files/files/MARCO%20JURIDICO/Aviso%20de%20privacidad%20actualizado.pdf">Privacy</a>
            <a href="https://tesci.edomex.gob.mx/acerca_sitio">Terms</a> 
        </div>
        <div class="footer-note one-half column">
            <div class="u-pull-right">
                <div class="flex">
                    <p>© TESCI 2025</p>
                    <a href="https://www.facebook.com/share/p/19CC8HfTrZ/"><img src={Twitter.src} alt="Twitter icon"></a>
                    <a href="https://www.tiktok.com/@comunidad.tesci?is_from_webapp=1&sender_device=pc"><img src={LinkedIn.src} alt="Linkedin icon"></a>
                </div>
            </div>
        </div>
    </div>
</footer>

<style lang="scss">
  .flex{
    display: flex;;
  }
footer{
    padding: 40px 0;
    background-color: #fff;

    a, p{
      color: #222;
      font-size: 1.8rem;
    }
    .footer-link a{
      padding-right: 20px;
      text-decoration: none;
    }
    .container{
      padding: 30px;
      border-radius: 50px;
      
      .footer-note{
        a{
          padding-left: 20px;
          img{
            width: 28px;
            @media (max-width: 700px) {
              width: 20px;
            }
          }
        }
      }
    }
    @media (max-width:700px) {
      p, a{
        font-size: 1.5rem;
      }
        .flex{
            justify-content: center;
        }
        .column{
            padding: 10px 0;
        }
        .u-pull-right{
            float: none;
        }
    }
  }
</style>