---
import Bomb from '../assets/bomb.svg'
import Mailbox from '../assets/mailbox.svg'
import Folder from '../assets/folder.svg'
import Savings from '../assets/savings.svg'
import Gift from '../assets/gift.svg'
import Rihno from '../assets/icorhino.svg'
import swRihno from '../assets/rinofin.svg'
import vlRihno from '../assets/volii.svg'
import wnRihno from '../assets/win.svg'
import bkRihno from '../assets/baske.svg'
---

<section class="product-hero">
    <div class="container">
        <div class="d-table">
            <div class="d-table-cell center">
                <div class="hero-copy">
                    
                    <h1 class="h1-title">
                        El Taller de Matemáticas del TESCI es un espacio para fortalecer aprendizaje académico.
                    </h1>

                    <p>
                        Mejora tus conocimientos en álgebra, cálculo y resolución de problemas matemáticos.
                       
                    </p>

                    <div class="product-cta">
                        <a href="#registro" class="button button-primary u-full-width">
                            Inscríbete
                        </a>
                    </div>

                </div>
            </div>
        </div>

        <div class="hero-media">
            <img src={swRihno.src} alt="Matemáticas TESCI">
            <img src={vlRihno.src} alt="Taller de matemáticas">
            <img src={wnRihno.src} alt="Aprendizaje matemático">
            <img src={bkRihno.src} alt="Estudio matemático">
            <img src={Rihno.src} alt="Rino TESCI">
        </div>
    </div>
</section>

<style lang="scss">

.product-hero{
  padding: 50px 0;

  .container{
    position: relative;

    .d-table{
      height: 500px;
    }
  }

  .hero-media{
    padding: 5px;
    border-radius: 48px;
  }

  .hero-copy{

    h1, p{
      max-width: 600px;
      margin: 20px auto;
      text-align: center;
    }

  }

  .hero-media{

    img{
      position: absolute;
      width: 160px;

      &:nth-child(1){
        top: 0;
        left: -100px;
      }

      &:nth-child(2){
        top: 0;
        right: -100px;
      }

      &:nth-child(3){
        top: 250px;
        left: 0;
      }

      &:nth-child(4){
        top: 250px;
        right: 0;
      }

      &:nth-child(5){
        bottom: -20px;
        left: 50%;
        transform: translateX(-50%);
      }

    }

    @media (max-width:700px) {

      img{

        &:nth-child(2),
        &:nth-child(3),
        &:nth-child(4){
          display: none;
        }

      }

    }

  }

}

</style>