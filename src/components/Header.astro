---
import logrihno from '../assets/svrino.svg'
---

<header class="nav">
  <div class="container row">
    <div class="nav-logo one-third column">
      <a href="/#registro" class="logo-link">
        <img src={logrihno.src} alt="Brand logo">
      </a>
    </div>

    <nav class="one-third column" id="main-nav">
      <ul class="center flex">
        <li><a href="/#features">Actividades</a></li>
        <li><a href="/test">Informacion</a></li>
        <li><a href="/challenge">Retos</a></li>
      </ul>
    </nav>

    <div class="nav-cta one-third column">
      <a href="/journal">Entrar</a>
      <a href="/#registro" class="button button-primary">Registrarse</a>
    </div>

    <button class="hamburger" id="hamburger" aria-label="Menú">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</header>

<script>
  const hamburger = document.getElementById("hamburger");
  const nav = document.getElementById("main-nav");

  hamburger?.addEventListener("click", () => {
    nav?.classList.toggle("open");
    hamburger.classList.toggle("active");
  });
</script>

<style lang="scss">
.nav {
  padding: 15px 0;
  position: relative;

  li {
    list-style: none;
    margin-top: 7px;
  }

  .nav-cta {
    text-align: right;
  }

  a:not(.button):not(.logo-link) {
    color: #111;
    padding: 0 20px;
    text-decoration: none;
  }

  .logo-link img {
    width: 40px;
    height: auto;
    margin-top: 5px;
  }

  /* ── Hamburger ── */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    position: absolute;
    right: 16px;
    top: 50%;
    transform: translateY(-50%);

    span {
      display: block;
      width: 24px;
      height: 2px;
      background: #111;
      border-radius: 2px;
      transition: all 0.25s ease;
    }

    &.active span:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
    }
    &.active span:nth-child(2) {
      opacity: 0;
    }
    &.active span:nth-child(3) {
      transform: translateY(-7px) rotate(-45deg);
    }
  }

  @media (max-width: 700px) {
  .hamburger {
    display: none;
  }

  .container {
    display: flex;
    flex-wrap: nowrap;
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none; /* oculta scrollbar en Firefox */
    gap: 8px;
    padding-bottom: 4px;

    &::-webkit-scrollbar {
      display: none; /* oculta scrollbar en Chrome/Safari */
    }
  }

  .nav-logo,
  nav,
  .nav-cta {
    flex-shrink: 0;
    width: auto !important;
    position: static;
    transform: none;
  }

  nav {
    display: block;

    ul {
      flex-wrap: nowrap;
      white-space: nowrap;
    }
  }

  .nav-cta {
    white-space: nowrap;
    text-align: left;
  }
}
}
</style>